AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Or use Claude API instead:
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Or use a PackyCode/OpenAI-compatible endpoint:
# AI_PROVIDER=packycode
# PACKYCODE_API_KEY=your-packycode-api-key
# PACKYCODE_MODEL=your-vision-model
# PACKYCODE_BASE_URL=https://your-packycode-openai-compatible-base-url/v1

# Optional if a deployed static frontend calls this backend from another origin:
# ALLOWED_ORIGINS=https://eddy-zhang-h.github.io
